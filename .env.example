# Database
POSTGRES_USER=usfx_admin
POSTGRES_PASSWORD=usfx_secret_2024
POSTGRES_DB=usfx_tramites
DATABASE_URL=postgresql+asyncpg://usfx_admin:usfx_secret_2024@postgres:5432/usfx_tramites

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Services
AI_SERVICE_URL=http://ai_service:8001
BACKEND_URL=http://backend:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# AI
WHISPER_MODEL=small
USE_GPU=true
BERT_MODEL=dccuchile/bert-base-spanish-wwm-cased
MAX_AUDIO_SIZE_MB=25

# Claude (Anthropic) — required for dynamic AI responses
# Get your key at https://console.anthropic.com/
CLAUDE_API_KEY=

# Optional: use Zero-Shot NLI model for aspect classification (more accurate, ~300MB download)
# Requires internet access on first start. Set to false to use fast keyword matching.
USE_ZERO_SHOT_CLASSIFIER=false
